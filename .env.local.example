# Supabase — same credentials as the Digital Home
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Digital Home API — the public-facing site's URL
DIGITAL_HOME_URL=http://localhost:3000
NEXT_PUBLIC_DIGITAL_HOME_URL=http://localhost:3000
API_SECRET_KEY=your-api-secret-key
API_SIGNATURE_REQUIRED=true
API_REQUEST_SIGNATURE_TTL_SECONDS=300
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
